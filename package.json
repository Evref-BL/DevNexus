{
  "name": "@evref-bl/dev-nexus",
  "version": "0.1.0-alpha.17",
  "private": false,
  "description": "Language-neutral project/work tracking and local execution core.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "dev-nexus": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run build && npm test && npm run check:plugins",
    "check:plugins": "npm --prefix plugins/dev-nexus-research run check"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
