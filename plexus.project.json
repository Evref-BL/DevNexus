{
  "name": "DevNexus Dogfood",
  "kanban": {
    "provider": "vibe-kanban",
    "projectId": "dev-nexus-dogfood"
  },
  "images": [],
  "imageExecution": {
    "mode": "disabled",
    "requireDisposableImage": true,
    "requireCleanupPlan": true,
    "docker": {
      "image": null,
      "network": "none",
      "autoRemove": true,
      "mountProjectReadOnly": true
    }
  },
  "runtime": {
    "gateway": {
      "mode": "project-local",
      "host": "127.0.0.1",
      "port": 17576,
      "agentMcpPath": "/mcp",
      "routeControlMcpPath": "/control-mcp"
    }
  }
}
