  "mcp": {
    "command": "node",
    "args": [
      "C:\\dev\\code\\pharo-nexus\\PharoNexus-Control\\worktrees\\DevNexus\\dist\\cli.js",
      "mcp-stdio"
    ],
    "agentTargets": [
      {
        "agent": "codex"
      },
      {
        "agent": "claude"
      }
    ]
  },
  "skills": {
    "defaultCorePack": true,
    "sourceControl": "support",
    "agentTargets": [
      {
        "agent": "codex"
      },
      {
        "agent": "claude"
      }
    ]
  },
  "automation": {
    "enabled": true,
    "mode": "agent_launch",
    "selector": {
      "statuses": [
        "ready"
      ],
      "labels": [
        "dogfood"
      ],
      "excludeLabels": [
        "blocked",
        "unsafe-live-runtime"
      ],
      "assignees": [],
      "search": null,
      "limit": 8
    },
    "verification": {
      "focusedCommands": [],
      "fullCommands": [],
      "requirePassing": true
    },
    "ledger": {
      "path": ".dev-nexus/automation/runs.json",
      "retention": 200
    },
    "lock": {
      "path": ".dev-nexus/automation/run.lock",
      "staleAfterMs": 3600000
    },
    "backoff": {
      "failureLimit": 3,
      "baseDelayMs": 300000,
      "maxDelayMs": 3600000
    },
    "schedule": {
      "enabled": true,
      "intervalMs": 900000
    },
    "setup": {
      "dependencyLinks": []
    },
    "executor": {
      "command": null,
      "timeoutMs": null,
      "runFullVerification": false
    },
    "agent": {
      "command": null,
      "timeoutMs": 2400000,
      "coordinatorProfileId": "codex-5-5-xhigh",
      "maxConcurrentSubagents": 8,
      "profiles": [
        {
          "id": "codex-5-5-xhigh",
          "executor": "codex",
          "model": "gpt-5.5",
          "reasoning": "xhigh",
          "command": "C:\\Users\\gabriel.darbord\\AppData\\Local\\OpenAI\\Codex\\bin\\codex.exe",
          "args": [
            "exec",
            "--model",
            "gpt-5.5",
            "-c",
            "model_reasoning_effort=xhigh",
            "-c",
            "approval_policy=never",
            "--sandbox",
            "danger-full-access",
            "--cd",
            "C:\\dev\\code\\dev-nexus-dogfood",
            "--add-dir",
            "C:\\dev\\code\\pharo-nexus\\PharoNexus-Control\\worktrees\\DevNexus",
            "--add-dir",
            "C:\\dev\\code\\pharo-nexus\\PharoNexus-Control\\worktrees\\MetaPharoNexus",
            "--add-dir",
            "C:\\dev\\code\\git\\PLexus",
            "--add-dir",
            "C:\\dev\\code\\git\\MCP-PL",
            "--add-dir",
            "C:\\Users\\gabriel.darbord\\Documents\\Pharo\\images\\MCP12-2\\pharo-local\\iceberg\\Evref-BL\\MCP",
            "--output-last-message",
            ".dev-nexus\\automation\\last-codex-message.md",
            "Use the DevNexus dogfood coordinator instructions in AGENTS.md. Read DEV_NEXUS_AGENT_CONTEXT_FILE, choose a safe bounded batch from eligible work items, update work items and target cycle records, and write JSON to DEV_NEXUS_AGENT_RESULT_FILE before exiting."
          ]
        },
        {
          "id": "codex-5-4-mini",
          "executor": "codex",
          "model": "gpt-5.4-mini",
          "reasoning": "medium",
          "command": "C:\\Users\\gabriel.darbord\\AppData\\Local\\OpenAI\\Codex\\bin\\codex.exe",
          "args": [
            "exec",
            "--model",
            "gpt-5.4-mini",
            "-c",
            "approval_policy=never",
            "--sandbox",
            "workspace-write",
            "--cd",
            "C:\\dev\\code\\dev-nexus-dogfood",
            "Read DEV_NEXUS_AGENT_CONTEXT_FILE and handle a small bounded verification or documentation work item."
          ]
        }
      ],
      "relaunch": {
        "whileEligible": true
      }
    },
    "target": {
      "id": "dev-nexus-dogfood",
      "objective": "Use DevNexus to drive work on itself and related components until the live plan is represented and advanced through component-owned work items.",
      "statePath": ".dev-nexus/automation/target-state.md",
      "cycleLedgerPath": ".dev-nexus/automation/target-cycles.json",
      "stopWhenNoEligibleWork": true,
      "maxCycles": 20,
      "maxWorkItems": 60
