    "safety": {
      "profile": "host-authorized",
      "allowHostMutation": true,
      "allowDependencyInstall": false,
      "allowLiveServices": false
    },
    "publication": {
      "strategy": "direct_integration",
      "remote": "origin",
      "targetBranch": "main",
      "push": true
