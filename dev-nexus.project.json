    {
      "id": "dev-nexus-pharo",
      "name": "DevNexus-Pharo",
      "kind": "git",
      "role": "extension",
      "remoteUrl": "git@github.com:Evref-BL/DevNexus-Pharo.git",
      "defaultBranch": "main",
      "sourceRoot": "C:\\dev\\code\\dev-nexus-control\\worktrees\\DevNexus-Pharo",
      "worktreesRoot": "worktrees/dev-nexus-pharo",
      "workTracking": {
        "provider": "local",
        "storePath": ".dev-nexus/work-items/dev-nexus-pharo.json"
      },
      "publication": {
        "strategy": "direct_integration",
        "remote": "origin",
        "targetBranch": "main",
        "push": true
      },
      "relationships": [
        {
          "kind": "extends",
          "componentId": "dev-nexus"
        },
        {
          "kind": "depends_on",
          "componentId": "plexus"
        }
      ]
    },
    {
      "id": "plexus",
      "name": "PLexus",
      "kind": "git",
      "role": "dependency",
      "remoteUrl": "git@github.com:Evref-BL/PLexus.git",
      "defaultBranch": "main",
      "sourceRoot": "C:\\dev\\code\\git\\PLexus",
      "worktreesRoot": "worktrees/plexus",
      "workTracking": {
        "provider": "local",
        "storePath": ".dev-nexus/work-items/plexus.json"
      },
      "publication": {
        "strategy": "direct_integration",
        "remote": "origin",
        "targetBranch": "main",
        "push": true
      },
      "relationships": []
    },
    {
      "id": "pharo-launcher-mcp",
      "name": "pharo-launcher-mcp",
      "kind": "git",
      "role": "dependency",
      "remoteUrl": "git@github.com:Evref-BL/pharo-launcher-mcp.git",
      "defaultBranch": "main",
      "sourceRoot": "C:\\dev\\code\\git\\pharo-launcher-mcp",
      "worktreesRoot": "worktrees/pharo-launcher-mcp",
      "workTracking": {
        "provider": "local",
        "storePath": ".dev-nexus/work-items/pharo-launcher-mcp.json"
      },
      "publication": {
        "strategy": "direct_integration",
        "remote": "origin",
        "targetBranch": "main",
        "push": true
      },
      "relationships": [
        {
          "kind": "related",
          "componentId": "plexus"
        }
      ]
    },
    {
      "id": "mcp-pharo",
      "name": "MCP-Pharo",
      "kind": "git",
      "role": "dependency",
      "remoteUrl": "https://github.com/Evref-BL/MCP.git",
      "defaultBranch": "main",
      "sourceRoot": "C:\\Users\\gabriel.darbord\\Documents\\Pharo\\images\\MCP12-2\\pharo-local\\iceberg\\Evref-BL\\MCP",
      "worktreesRoot": "worktrees/mcp-pharo",
      "workTracking": {
        "provider": "local",
        "storePath": ".dev-nexus/work-items/mcp-pharo.json"
      },
      "publication": {
        "strategy": "review_handoff",
        "remote": "origin",
        "targetBranch": "main",
        "push": false
