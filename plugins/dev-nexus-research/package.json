{
  "name": "@evref-bl/dev-nexus-research",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Additive DevNexus plugin skeleton for research-project workflows.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "fixtures",
    "skills",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "check": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
